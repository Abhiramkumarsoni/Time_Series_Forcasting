# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ─── Virtual environments ─────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ─── Distribution / packaging ─────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb_checkpoints/

# ─── Data & models (large binary files) ──────────────────────────────────────
data/raw/*.csv
data/raw/*.xlsx
data/processed/*.csv
data/processed/*.pkl
models/*.pkl
models/*.keras
models/*.h5

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Reports / figures ────────────────────────────────────────────────────────
reports/figures/*.png
reports/figures/*.html
reports/metrics/*.json

# ─── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ─── Type checking ────────────────────────────────────────────────────────────
.mypy_cache/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
